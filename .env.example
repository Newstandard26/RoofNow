# RoofNow environment variables (server-side only).
#
# Copy to `.env` for local use, or set these in the Vercel project
# (Settings -> Environment Variables). The Python serverless function
# api/measure.py reads them at request time — they are NEVER sent to the
# browser, so the key stays server-side.

# Google Cloud API key with the **Solar API** and **Geocoding API** enabled.
# When set, /api/measure switches from demo data to live Google Solar
# lookups. Leave blank to run in demo mode.
GOOGLE_MAPS_API_KEY=

# Per-client-IP rate limit for /api/measure (requests per minute; 0 disables).
# Protects the paid Google APIs in live mode. Defaults to 30 if unset.
RATELIMIT_PER_MIN=30

# --- RoofNow instant quote ---------------------------------------------------

# Per-client-IP rate limit for /api/lead (submissions per minute). Default 10.
LEAD_RATELIMIT_PER_MIN=10

# Editable pricing (rate card). Highest precedence first; all optional — with
# none set, the built-in defaults are used. Edit pricing.config.json (copy from
# pricing.config.example.json) to change prices with no code change/redeploy.
ROOFNOW_PRICING_JSON=
ROOFNOW_PRICING_FILE=

# --- Lead funnel (all optional; unconfigured channels are skipped) -----------

# Zapier / CRM: leads are POSTed as a flat, CRM-ready JSON payload to this
# webhook. Point it at a Zapier "Catch Hook" that creates an AccuLynx Lead +
# a LeadConnector (GoHighLevel) Contact. Full recipe + field mapping:
# docs/instant-quote/08_ZAPIER_SETUP.md
LEAD_WEBHOOK_URL=

# Slack: an Incoming Webhook URL — each lead is posted to that channel.
SLACK_WEBHOOK_URL=

# Email: SMTP credentials for the team notification email. LEAD_NOTIFY_TO
# defaults to mattk@newstandardrestoration.com. For Gmail, use an App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
LEAD_NOTIFY_TO=
LEAD_NOTIFY_FROM=
