# RoofNow environment variables (server-side only).
#
# Copy to `.env` for local use, or set these in the Vercel project
# (Settings -> Environment Variables). The Python serverless function
# api/measure.py reads them at request time — they are NEVER sent to the
# browser, so the key stays server-side.

# Google Cloud API key with the **Solar API** and **Geocoding API** enabled.
# When set, /api/measure switches from demo data to live Google Solar
# lookups. Leave blank to run in demo mode.
GOOGLE_MAPS_API_KEY=

# Per-client-IP rate limit for /api/measure (requests per minute; 0 disables).
# Protects the paid Google APIs in live mode. Defaults to 30 if unset.
RATELIMIT_PER_MIN=30
